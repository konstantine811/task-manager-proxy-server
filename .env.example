PORT=8787
APP_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FREE_TRIAL_DAYS=7
PAID_ACCESS_DAYS=30
BILLING_PROVIDER=wayforpay

# Firebase Admin.
# Use either GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/service-account.json
# or paste the JSON into FIREBASE_SERVICE_ACCOUNT_JSON.
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_STORAGE_BUCKET=abc-folio.firebasestorage.app

# Gemini server-side key. Do not expose this as VITE_*.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# WayForPay hosted subscription page.
WAYFORPAY_SUBSCRIPTION_URL=https://secure.wayforpay.com/sub/s1a4266d903dc
WAYFORPAY_MERCHANT_ACCOUNT=
WAYFORPAY_SECRET_KEY=
WAYFORPAY_CURRENCY=UAH
WAYFORPAY_STARTER_AMOUNT=120
WAYFORPAY_PRO_AMOUNT=200
