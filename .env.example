PORT=8787
APP_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FREE_TRIAL_DAYS=7
PAID_ACCESS_DAYS=30
ADMIN_EMAILS=constainabrams@gmial.com

# Firebase Admin.
# Use either GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/service-account.json
# or paste the JSON into FIREBASE_SERVICE_ACCOUNT_JSON.
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_STORAGE_BUCKET=abc-folio.firebasestorage.app

# Gemini server-side key. Do not expose this as VITE_*.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Portmone payment gateway.
PORTMONE_GATEWAY_URL=https://www.portmone.com.ua/gateway/
PORTMONE_PAYEE_ID=
PORTMONE_LOGIN=
PORTMONE_PASSWORD=
PORTMONE_SIGNATURE_KEY=
PORTMONE_CURRENCY=UAH
PORTMONE_LANGUAGE=uk
PORTMONE_STARTER_AMOUNT=120
PORTMONE_PRO_AMOUNT=200
